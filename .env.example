# === INSTÂNCIA ===
INSTANCE_ID=minha-instancia
APP_PORT=8000
SITE_URL=https://meusite.com.br
LOG_LEVEL=INFO
SITE_NAME=Meu Chatbot WhatsApp

# === AUTH ===
LOGIN_USER=admin
LOGIN_PASSWORD=sua-senha-aqui
SECRET_KEY=gere-uma-chave-secreta-aleatoria-de-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# === DATABASE ===
DATABASE_URL=mysql://usuario:senha@db:3306/shopify_bot
REDIS_URL=redis://redis:6379/0

# === SHOPIFY ===
SHOPIFY_STORE_URL=sua-loja.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01
SHOPIFY_WEBHOOK_SECRET=

# === LLM (OpenRouter) ===
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
LLM_MODEL_PREFERENCE=z-ai/glm-5
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=90

# === CHATBOT ===
MESSAGE_BUFFER_SECONDS=15

# === DOCKER ===
RUNNING_IN_SHOPIFY_BOT_DOCKER=true
